{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--disable-extensions",
        "--user-data-dir=${workspaceFolder}/.vscode-test/debug-user-data",
        "--extensions-dir=${workspaceFolder}/.vscode-test/debug-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "preLaunchTask": "pnpm: build",
      "outFiles": ["${workspaceFolder}/dist/**/*.js", "${workspaceFolder}/dist/**/*.cjs"]
    }
  ]
}
